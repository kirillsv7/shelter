{
    "preset": "psr12",
    "rules": {
        "binary_operator_spaces": {
            "default": "single_space"
        },
        "blank_line_before_statement": {
            "statements": [
                "break",
                "continue",
                "return",
                "throw"
            ]
        },
        "trailing_comma_in_multiline": true
    }
}
